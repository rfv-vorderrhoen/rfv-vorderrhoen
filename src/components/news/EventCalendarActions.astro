---
import type { CollectionEntry } from "astro:content";
import { getCalendarLinks } from "@/lib/calendar";

interface Props {
    entry: CollectionEntry<"news">;
    compact?: boolean;
}

const { entry, compact = false } = Astro.props;
const links = getCalendarLinks(entry, Astro.site);
---

{
    entry.data.isEvent && (
        <div
            class:list={[
                "grid w-full max-w-[29rem] grid-cols-[minmax(0,1fr)_auto_auto_auto] items-stretch overflow-hidden rounded-full border border-[var(--color-line)] bg-white/72 shadow-[var(--shadow-soft)]",
                compact ? "text-xs" : "text-sm",
            ]}
        >
            <span
                class:list={[
                    "inline-flex min-w-0 items-center gap-2 border-r border-[var(--color-line)] bg-[rgba(255,252,247,0.88)] px-3 font-semibold leading-tight text-[var(--color-forest)] sm:px-4",
                    compact ? "min-h-10" : "min-h-11",
                ]}
            >
                <svg
                    viewBox="0 0 24 24"
                    class:list={[compact ? "h-4 w-4" : "h-5 w-5", "shrink-0"]}
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.7"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                >
                    <rect x="3.5" y="5" width="17" height="15.5" rx="3" />
                    <path d="M7.5 3.5v3" />
                    <path d="M16.5 3.5v3" />
                    <path d="M3.5 9.5h17" />
                    <path d="M8 13h3" />
                    <path d="M13 13h3" />
                    <path d="M8 17h3" />
                </svg>
                <span class="min-w-0">Zum Kalender hinzufügen</span>
            </span>
            <a
                href={links.google}
                target="_blank"
                rel="noreferrer"
                aria-label="Zu Google Kalender hinzufügen"
                class:list={[
                    "inline-flex items-center justify-center border-r border-[var(--color-line)] text-[var(--color-ink)] transition duration-300 hover:bg-white/90",
                    compact ? "min-h-10 w-10" : "min-h-11 w-12",
                ]}
            >
                <span class="sr-only">Google Kalender</span>
                <svg
                    viewBox="0 0 24 24"
                    class:list={[compact ? "h-4 w-4" : "h-5 w-5", "shrink-0"]}
                    aria-hidden="true"
                >
                    <path
                        fill="#4285F4"
                        d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
                    />
                    <path
                        fill="#34A853"
                        d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                    />
                    <path
                        fill="#FBBC05"
                        d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
                    />
                    <path
                        fill="#EA4335"
                        d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84C6.71 7.31 9.14 5.38 12 5.38z"
                    />
                </svg>
            </a>
            <a
                href={links.apple}
                aria-label="Zu Apple Kalender hinzufügen"
                class:list={[
                    "inline-flex items-center justify-center border-r border-[var(--color-line)] text-[#1f1f1f] transition duration-300 hover:bg-white/90",
                    compact ? "min-h-10 w-10" : "min-h-11 w-12",
                ]}
            >
                <span class="sr-only">Apple Kalender</span>
                <svg
                    viewBox="0 0 16 16"
                    class:list={[compact ? "h-4 w-4" : "h-5 w-5", "shrink-0"]}
                    fill="currentColor"
                    aria-hidden="true"
                >
                    <path d="M11.182.008C11.148-.03 9.923.023 8.857 1.18c-1.066 1.156-.902 2.482-.878 2.516.024.034 1.52.087 2.475-1.258.955-1.345.762-2.391.728-2.43Z" />
                    <path d="M14.496 11.741c-.048-.096-2.325-1.234-2.113-3.422.212-2.189 1.675-2.789 1.698-2.854.023-.065-.597-.79-1.254-1.157a3.692 3.692 0 0 0-1.563-.434c-.108-.003-.483-.095-1.254.116-.508.139-1.653.589-1.968.607-.316.018-1.256-.522-2.267-.665-.647-.125-1.333.131-1.824.328-.49.196-1.422.754-2.074 2.237-.652 1.482-.311 3.83-.067 4.56.244.729.625 1.924 1.273 2.796.576.984 1.34 1.667 1.659 1.899.319.232 1.219.386 1.843.067.502-.308 1.408-.485 1.766-.472.357.013 1.061.154 1.782.539.571.197 1.111.115 1.652-.105.541-.221 1.324-1.059 2.238-2.758.347-.79.505-1.217.473-1.282Z" />
                </svg>
            </a>
            <a
                href={links.outlook}
                target="_blank"
                rel="noreferrer"
                aria-label="Zu Outlook Kalender hinzufügen"
                class:list={[
                    "inline-flex items-center justify-center transition duration-300 hover:bg-white/90",
                    compact ? "min-h-10 w-10" : "min-h-11 w-12",
                ]}
            >
                <span class="sr-only">Outlook Kalender</span>
                <svg
                    viewBox="0 0 24 24"
                    class:list={[compact ? "h-4 w-4" : "h-5 w-5", "shrink-0"]}
                    aria-hidden="true"
                >
                    <path fill="#F25022" d="M3 3h8.5v8.5H3z" />
                    <path fill="#7FBA00" d="M12.5 3H21v8.5h-8.5z" />
                    <path fill="#00A4EF" d="M3 12.5h8.5V21H3z" />
                    <path fill="#FFB900" d="M12.5 12.5H21V21h-8.5z" />
                </svg>
            </a>
        </div>
    )
}
