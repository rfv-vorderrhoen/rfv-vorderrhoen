---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageIntro from "@/components/ui/PageIntro.astro";
import Section from "@/components/ui/Section.astro";
import Button from "@/components/ui/Button.astro";
import FaqAccordion from "@/components/ui/FaqAccordion";
import GoogleFormEmbed from "@/components/forms/GoogleFormEmbed.astro";
import LocationMap from "@/components/ui/LocationMap.astro";
import { faqItems, siteConfig, socialLinks } from "@/lib/site";

interface Props {
    entry: CollectionEntry<"pages">;
}

type PricingEntry = CollectionEntry<"pricing">;
type MembershipBlock = {
    key: string;
    eyebrow: string;
    title: string;
    description: string;
    note: string;
    items: PricingEntry[];
};
type MembershipFitRow = {
    situation: string;
    structure: string;
    note: string;
};

const membershipGroupLabel = "Vereinsmitgliedschaft";
const trainingGroupLabel = "Aktive Trainingsmitgliedschaft";

const { entry } = Astro.props;
const { Content } = await entry.render();
const pricingEntries =
    entry.slug === "pricing"
        ? (await getCollection("pricing")).sort(
              (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
          )
        : [];
let clubMemberships: PricingEntry[] = [];
let trainingMemberships: PricingEntry[] = [];
let additionalMemberships: PricingEntry[] = [];
let membershipBlocks: MembershipBlock[] = [];
const membershipFitRows: MembershipFitRow[] = [
    {
        situation: "Kind oder Jugendliche:r trainiert",
        structure: "Kinder bis 18 Jahren + aktive Teilnahme",
        note: "Ein oder zwei feste Trainingstermine pro Woche, passend zur Gruppe.",
    },
    {
        situation: "Erwachsene Person trainiert",
        structure: "Erwachsene + aktive Teilnahme",
        note: "Für volljährige aktive Mitglieder im regulären Trainingsbetrieb.",
    },
    {
        situation: "Mehrere Familienmitglieder sind dabei",
        structure: "Familien + aktive Teilnahme für trainierende Mitglieder",
        note: "Sinnvoll, wenn die Mitgliedschaft gemeinsam organisiert werden soll.",
    },
    {
        situation: "Unterstützung ohne regelmäßiges Training",
        structure: "Fördermitglied",
        note: "Für erwachsene unterstützende Mitglieder ohne aktive Teilnahme.",
    },
    {
        situation: "Reitbeteiligung oder individuelle Pferdearbeit",
        structure: "Mitgliedschaft + persönliche Absprache",
        note: "Nur nach Eignung, Verantwortung und verfügbarer Kapazität.",
    },
];

if (entry.slug === "pricing") {
    clubMemberships = pricingEntries.filter(
        (item) => item.data.groupLabel === membershipGroupLabel,
    );
    trainingMemberships = pricingEntries.filter(
        (item) => item.data.groupLabel === trainingGroupLabel,
    );
    additionalMemberships = pricingEntries.filter(
        (item) =>
            item.data.groupLabel !== membershipGroupLabel &&
            item.data.groupLabel !== trainingGroupLabel,
    );

    membershipBlocks = [
        {
            key: "club-memberships",
            eyebrow: "Verein",
            title: "Vereinsmitgliedschaft",
            description:
                "Die Grundlage für Personen oder Familien, die Teil des Vereins sind.",
            note: "Eine Form reicht als Basis.",
            items: clubMemberships,
        },
        {
            key: "active-training",
            eyebrow: "Training",
            title: "Aktive Teilnahme",
            description:
                "Kommt nur dazu, wenn jemand regelmäßig am Voltigiertraining teilnimmt.",
            note: "Zusätzlich zur Vereinsmitgliedschaft.",
            items: trainingMemberships,
        },
        {
            key: "additional-options",
            eyebrow: "Individuell",
            title: "Zusätzliche Beteiligung",
            description:
                "Für unterstützende Mitgliedschaft oder besondere Formen wie Reitbeteiligung.",
            note: "Je nach Form nach persönlicher Absprache.",
            items: additionalMemberships,
        },
    ].filter((block) => block.items.length > 0);
}
---

<BaseLayout
    title={entry.data.seoTitle ?? `${entry.data.title} | RFV Vorderrhön`}
    description={entry.data.seoDescription ?? entry.data.description}
>
    <Section spaced={false} className="pb-4 pt-10 md:pb-6 md:pt-16">
        <PageIntro
            title={entry.data.title}
            description={entry.data.description}
        />
    </Section>
    {
        entry.body && (
            <Section spaced={false} className="pb-8 pt-8 md:pb-10">
                <article class="panel rich-text px-6 pb-8 pt-4 md:px-10 md:pb-10 md:pt-6">
                    <Content />
                </article>
            </Section>
        )
    }

    {
        entry.slug === "pricing" && (
            <>
                <Section spaced={false} className="pb-8 pt-0 md:pb-10">
                    <div class="max-w-3xl">
                        <span class="eyebrow">Struktur</span>
                        <h2 class="mt-3 text-3xl md:text-4xl">
                            Mitgliedschaft als Bausteine
                        </h2>
                        <p class="mt-4 text-[var(--color-soft-ink)]">
                            Erst die passende Vereinsmitgliedschaft, dann bei
                            aktivem Training die Teilnahmeform. Individuelle
                            Optionen klären wir separat.
                        </p>
                    </div>

                    <div class="mt-6 grid gap-5 lg:grid-cols-3">
                        {membershipBlocks.map((block, index) => (
                            <article
                                class="panel flex h-full flex-col p-6 md:p-7"
                                id={block.key}
                            >
                                <div class="flex items-center gap-3">
                                    <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-[var(--color-forest)] text-sm font-semibold text-[var(--color-cream-strong)]">
                                        {String(index + 1).padStart(2, "0")}
                                    </span>
                                    <span class="eyebrow">
                                        {block.eyebrow}
                                    </span>
                                </div>
                                <h3 class="mt-5 text-2xl leading-tight md:text-3xl">
                                    {block.title}
                                </h3>
                                <p class="mt-4 text-sm leading-7 text-[var(--color-soft-ink)]">
                                    {block.description}
                                </p>
                                <ul class="mt-6 divide-y divide-[var(--color-line)] border-y border-[var(--color-line)]">
                                    {block.items.map((item) => (
                                        <li class="py-3">
                                            <p class="font-semibold leading-6">
                                                {item.data.name}
                                            </p>
                                            <p class="mt-1 text-sm leading-6 text-[var(--color-soft-ink)]">
                                                {item.data.description}
                                            </p>
                                        </li>
                                    ))}
                                </ul>
                                <p class="mt-5 text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-moss)]">
                                    {block.note}
                                </p>
                            </article>
                        ))}
                    </div>
                </Section>

                <Section spaced={false} className="pb-8 pt-0 md:pb-10">
                    <div class="panel overflow-hidden">
                        <div class="border-b border-[var(--color-line)] p-6 md:p-8">
                            <span class="eyebrow">Einordnung</span>
                            <h2 class="mt-3 text-3xl md:text-4xl">
                                Was passt zu mir?
                            </h2>
                        </div>
                        <div class="hidden grid-cols-[0.9fr_1fr_1.1fr] gap-5 border-b border-[var(--color-line)] bg-white/45 px-6 py-3 text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-moss)] md:grid md:px-8">
                            <span>Situation</span>
                            <span>Passende Struktur</span>
                            <span>Hinweis</span>
                        </div>
                        <div class="divide-y divide-[var(--color-line)]">
                            {membershipFitRows.map((row) => (
                                <div class="grid gap-4 px-6 py-5 md:grid-cols-[0.9fr_1fr_1.1fr] md:gap-5 md:px-8">
                                    <div>
                                        <span class="text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-moss)] md:hidden">
                                            Situation
                                        </span>
                                        <p class="mt-1 font-semibold md:mt-0">
                                            {row.situation}
                                        </p>
                                    </div>
                                    <div>
                                        <span class="text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-moss)] md:hidden">
                                            Passende Struktur
                                        </span>
                                        <p class="mt-1 text-[var(--color-forest)] md:mt-0">
                                            {row.structure}
                                        </p>
                                    </div>
                                    <div>
                                        <span class="text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-moss)] md:hidden">
                                            Hinweis
                                        </span>
                                        <p class="mt-1 text-sm leading-7 text-[var(--color-soft-ink)] md:mt-0">
                                            {row.note}
                                        </p>
                                    </div>
                                </div>
                            ))}
                        </div>
                    </div>
                </Section>

                <Section spaced={false} className="pb-8 pt-0 md:pb-10">
                    <div class="panel flex flex-col gap-6 p-8 md:flex-row md:items-center md:justify-between md:p-10">
                        <div>
                            <span class="eyebrow">Anfrage</span>
                            <h2 class="mt-4 text-3xl md:text-4xl">
                                Mitgliedschaft oder Probetraining anfragen.
                            </h2>
                        </div>
                        <Button href={siteConfig.signupUrl}>
                            Anfrage starten
                        </Button>
                    </div>
                </Section>
            </>
        )
    }

    {
        entry.slug === "faq" && (
            <Section className="pt-0">
                <FaqAccordion client:visible items={faqItems} />
            </Section>
        )
    }

    {
        entry.slug === "contact" && (
            <Section className="pt-0">
                <div class="grid gap-5">
                    <div class="grid gap-5 xl:grid-cols-[1.05fr_0.95fr] xl:items-start">
                        <div class="grid gap-5">
                            <div class="panel p-6">
                                <p class="text-sm uppercase tracking-[0.16em] text-[var(--color-moss)]">
                                    E-Mail
                                </p>
                                <a
                                    class="mt-3 block text-xl font-semibold"
                                    href={`mailto:${siteConfig.email}`}
                                >
                                    {siteConfig.email}
                                </a>
                            </div>
                            <div class="panel p-6">
                                <p class="text-sm uppercase tracking-[0.16em] text-[var(--color-moss)]">
                                    Telefon
                                </p>
                                <a
                                    class="mt-3 block text-xl font-semibold"
                                    href={`tel:${siteConfig.phone.replace(/\s+/g, "")}`}
                                >
                                    {siteConfig.phone}
                                </a>
                            </div>
                            <div class="panel p-6">
                                <p class="text-sm uppercase tracking-[0.16em] text-[var(--color-moss)]">
                                    Probetraining
                                </p>
                                <Button
                                    href={siteConfig.signupUrl}
                                    className="mt-3"
                                >
                                    Probetraining anfragen
                                </Button>
                            </div>
                        </div>

                        <div class="panel p-6 md:p-8">
                            <span class="eyebrow">Socials</span>
                            <h2 class="mt-4 text-3xl md:text-4xl">
                                Instagram-Accounts für Verein und Teams
                            </h2>
                            <div class="mt-6 grid gap-4">
                                {socialLinks.map((item) => (
                                    <a
                                        class="relative overflow-hidden rounded-[1.3rem] border border-[var(--color-line)] bg-white/55 px-5 py-4 pr-18 transition hover:-translate-y-0.5 hover:border-[var(--color-moss)]"
                                        href={item.href}
                                        target="_blank"
                                        rel="noreferrer"
                                    >
                                        <span class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-[var(--color-moss)] opacity-18">
                                            <svg
                                                aria-hidden="true"
                                                viewBox="0 0 24 24"
                                                class="h-12 w-12"
                                                fill="none"
                                                stroke="currentColor"
                                                stroke-width="1.5"
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                            >
                                                <rect
                                                    x="3.5"
                                                    y="3.5"
                                                    width="17"
                                                    height="17"
                                                    rx="5"
                                                />
                                                <circle
                                                    cx="12"
                                                    cy="12"
                                                    r="4"
                                                />
                                                <circle
                                                    cx="17.35"
                                                    cy="6.65"
                                                    r="0.8"
                                                    fill="currentColor"
                                                    stroke="none"
                                                />
                                            </svg>
                                        </span>
                                        <span class="block text-xs uppercase tracking-[0.14em] text-[var(--color-moss)]">
                                            {item.platform}
                                        </span>
                                        <span class="mt-2 block text-xl font-semibold">
                                            {item.label}
                                        </span>
                                        <span class="mt-1 block text-[var(--color-soft-ink)]">
                                            {item.handle}
                                        </span>
                                    </a>
                                ))}
                            </div>
                        </div>
                    </div>

                    <LocationMap
                        eyebrow="Anfahrt"
                        title="So findest du den Verein"
                        description="Nutze die eingebettete Karte für die Orientierung vor Ort oder öffne den Standort direkt in Google Maps für deine Anfahrt."
                    />
                </div>
            </Section>
        )
    }

    {
        entry.slug === "probetraining-anfragen" && (
            <Section className="pt-0">
                <GoogleFormEmbed
                    title="Probetraining anfragen"
                    description="Wenn die Einbettung in deinem Browser nicht korrekt geladen wird, kannst du das Formular jederzeit über den Direktlink bei Google öffnen."
                    formUrl={siteConfig.signupFormUrl}
                />
            </Section>
        )
    }

    {
        false && (
            <Section className="pt-0">
                <GoogleFormEmbed
                    title="Anmeldung direkt ausfüllen"
                    description="Wenn die Einbettung in deinem Browser nicht korrekt geladen wird, kannst du das Formular jederzeit über den Direktlink bei Google öffnen."
                    formUrl={siteConfig.signupFormUrl}
                />
            </Section>
        )
    }
</BaseLayout>
